{
    "annotations": { "list": [] },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "id": null,
    "links": [],
    "liveNow": true,
    "panels": [
      {
        "title": "Login Attempts Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          {
            "expr": "rate(login_attempts_total[1m])",
            "legendFormat": "login attempts/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
        },
        "options": { "legend": { "showLegend": true } }
      },
      {
        "title": "Success vs Failed Logins",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          {
            "expr": "login_success_total",
            "legendFormat": "Successful logins",
            "refId": "A"
          },
          {
            "expr": "login_failure_total",
            "legendFormat": "Failed logins",
            "refId": "B"
          }
        ],
        "options": {
          "legend": { "showLegend": true, "placement": "bottom" },
          "pieType": "pie",
          "displayLabels": ["percent", "value"]
        }
      },
      {
        "title": "Request Rate (RPS)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[1m])) by (endpoint)",
            "legendFormat": "{{endpoint}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
        },
        "options": { "legend": { "showLegend": true } }
      },
      {
        "title": "API Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, endpoint))",
            "legendFormat": "{{endpoint}} p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, endpoint))",
            "legendFormat": "{{endpoint}} p50",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
        },
        "options": { "legend": { "showLegend": true } }
      },
      {
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          { "expr": "active_sessions", "refId": "A" }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
        }
      },
      {
        "title": "Total Registrations",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          { "expr": "registrations_total", "refId": "A" }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
        }
      },
      {
        "title": "Total Requests",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          { "expr": "sum(http_requests_total)", "refId": "A" }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
        }
      },
      {
        "title": "Login Success Rate",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "targets": [
          {
            "expr": "100 * (login_success_total / (login_success_total + login_failure_total))",
            "refId": "A"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percent" } },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
        }
      }
    ],
    "refresh": "5s",
    "schemaVersion": 39,
    "tags": ["authentication", "monitoring"],
    "templating": { "list": [] },
    "time": { "from": "now-15m", "to": "now" },
    "timepicker": {},
    "timezone": "browser",
    "title": "Authentication Service Monitoring",
    "uid": "auth-service-monitoring",
    "version": 1,
    "weekStart": ""
  }